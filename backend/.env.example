# ORCA backend env

# Apify token for X scraping. If unset, the backend uses seeded demo data.
APIFY_TOKEN=

# Apify actor used to scrape X. Default: apidojo/tweet-scraper
APIFY_ACTOR=apidojo/tweet-scraper

# Operator handle to monitor (case study: MTN Nigeria)
OPERATOR_HANDLE=MTNNigeria
OPERATOR_NAME=MTN Nigeria

# Anthropic key for tweet classification + AI reply drafting.
# If unset, the backend uses a deterministic mock classifier.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# SQLite path
DATABASE_URL=sqlite:///./orca.db
